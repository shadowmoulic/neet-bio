{
  "headers": [
    {
      "source": "/(.*).(css|js|woff2|png|jpg|svg|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/admin/", "destination": "/admin.html" },
    { "source": "/((?!api|admin|privacy|terms|guide|notes|mcq|compare|flashcards|glossary|pricing|home-demo|.*\\.).*)", "destination": "/index.html" }
  ]
}
